@model Core.ViewModels.ApplicationUserViewModel
@{
	Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "ForgotPassword";
}


<div class="container-fluid">

	<!-- Account Logo -->
	<div class="account-logo" style="margin-top: 80px;">
		<a href="index.html"><img src="/light/assets/img/logo.png"></a>
	</div>
	<!-- /Account Logo -->

	<div class="account-box mt-3">
		<div class="account-wrapper">
			<h3 class="account-title">Forgot Password?</h3>
			<p class="account-subtitle">Enter your email to get a password reset link</p>

			<!-- Account Form -->

			<div class="form-group">
				<label><b>Email Address</b></label>
				<input id="emailAddress" class="form-control" type="text">
			</div>
			<div class="form-group text-center">
				<button class="btn btn-primary account-btn" type="submit" onclick="ForgotPassword()">Reset Password</button>
			</div>
			<div class="account-footer">
				<p>Remember your password? <a asp-action="Login" asp-controller="Account">Login</a></p>
			</div>

			<!-- /Account Form -->

		</div>
	</div>
</div>
