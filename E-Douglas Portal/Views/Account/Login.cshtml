 *@
 @{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Login";
}

<style>
    .auth-page {
        min-height: 100vh;
        background: linear-gradient(rgba(15,23,42,0.92), rgba(21,3,122,0.88));
        display: flex;
        align-items: center;
        position: relative;
    }

    .bg-video {
        position: fixed;
        top: 0; left: 0; width: 100%; height: 100%;
        object-fit: cover;
        z-index: -1;
        filter: brightness(0.6) contrast(1.15);
    }

    .auth-card {
        max-width: 440px;
        margin: 40px auto;
        background: rgba(255,255,255,0.95);
        backdrop-filter: blur(16px);
        border-radius: 24px;
        box-shadow: 0 20px 60px rgba(21,3,122,0.25);
        padding: 40px 35px;
        border: 1px solid rgba(0,212,255,0.2);
    }

    .auth-card h2 {
        font-size: 2.1rem;
        font-weight: 700;
        background: linear-gradient(90deg, #15037A, #00D4FF);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .form-control {
        border-radius: 12px;
        padding: 14px 18px;
        border: 2px solid #e2e8f0;
        transition: all 0.3s ease;
    }

    .form-control:focus {
        border-color: #00D4FF;
        box-shadow: 0 0 0 4px rgba(0,212,255,0.15);
    }

    .btn-login {
        background: linear-gradient(90deg, #15037A, #00D4FF);
        border: none;
        border-radius: 50px;
        padding: 16px;
        font-size: 1.15rem;
        font-weight: 600;
        box-shadow: 0 10px 30px rgba(0,212,255,0.4);
    }

    .btn-login:hover {
        transform: translateY(-3px);
        box-shadow: 0 15px 35px rgba(0,212,255,0.5);
    }
</style>

<video autoplay muted loop playsinline class="bg-video">
    <source src="~/video/vecteezy_tashkent-uzbekistan-8-4-2022-close-up-of-hands-of-people_42649759.mov" type="video/mp4">
</video>

<div class="auth-page">
    <div class="auth-card" data-aos="zoom-in" data-aos-delay="100">
        <div class="text-center mb-4">
            <img src="~/Images/EDOUGLAS ACADEMY LOGO.jpg" alt="E-Douglas Academy" class="img-fluid mb-3" style="height: 68px;">
            <h2>Welcome Back</h2>
            <p class="text-muted">Sign in to continue your learning journey</p>
        </div>

        <div class="mb-4">
            <label class="form-label fw-semibold">Email Address</label>
            <input type="email" id="email" class="form-control" placeholder="you@email.com" required />
        </div>

        <div class="mb-4">
            <label class="form-label fw-semibold">Password</label>
            <input type="password" id="password" class="form-control" placeholder="Enter your password" required />
        </div>

        <div class="d-flex justify-content-between align-items-center mb-4">
            <a href="/Account/ForgotPassword" class="text-primary fw-medium">Forgot Password?</a>
        </div>

        <button type="button" id="submit_btn" onclick="login()" class="btn btn-login text-white w-100 mb-3">
            Login to Your Account
        </button>

        <p class="text-center text-muted">
            Don’t have an account? 
            <a href="/Account/Register" class="fw-semibold text-primary">Create one now →</a>
        </p>
    </div>
</div>