@* @{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Register";
}
<style>
    .bg-video {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        z-index: -1;
        filter: brightness(60%);
    }

    .auth-card {
        max-width: 420px;
        margin: 100px auto;
        background: #fff;
        border-radius: 10px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
        padding: 2rem;
        z-index: 10;
        position: relative;
    }

        .auth-card h2 {
            font-weight: 600;
            color: #9333ea;
        }

    .custom-checkbox {
        width: 26px;
        height: 26px;
        border: 2px solid #e9d5ff;
        border-radius: 8px;
        appearance: none;
        -webkit-appearance: none;
        outline: none;
        cursor: pointer;
        flex-shrink: 0;
        margin-top: 2px;
        transition: all 0.2s;
    }

        .custom-checkbox:checked {
            background-color: #9333ea;
            border-color: #9333ea;
        }

            .custom-checkbox:checked::after {
                content: '✓';
                color: white;
                font-size: 18px;
                font-weight: bold;
                position: absolute;
                top: 50%;
                left: 50%;
                transform: translate(-50%, -50%);
            }

    .form-check {
        display: flex;
        align-items: flex-start;
        gap: 14px;
        margin-bottom: 18px;
    }

    .form-check-label {
        font-size: 15px;
        line-height: 1.6;
        color: #333;
        padding-top: 2px;
    }

        .form-check-label a {
            color: #9333ea;
            text-decoration: underline;
            font-weight: 500;
        }

    .checkbox-container {
        background: #f8f5ff;
        border-radius: 12px;
        padding: 20px 22px;
        margin: 10px 0 25px 0;
        border: 1px solid #e9d5ff;
    }

    .checkbox-title {
        font-weight: 600;
        color: #1e1e5d;
        margin-bottom: 16px;
        font-size: 16px;
    }

    #checkboxWarning {
        background: #fee2e2;
        color: #991b1b;
        border: 1px solid #fecaca;
        border-radius: 8px;
        padding: 12px;
        text-align: center;
        font-size: 14px;
        display: none;
    }

    .btn-create {
        background: linear-gradient(to right, #9333ea, #7c3aed);
        border: none;
        border-radius: 12px;
        padding: 14px;
        font-size: 17px;
        font-weight: 600;
    }
</style>

<!-- Background Video -->
<video autoplay muted loop playsinline class="bg-video">
    <source src="~/video/vecteezy_tashkent-uzbekistan-8-4-2022-close-up-of-hands-of-people_42649759.mov" type="video/mp4">
</video>
<div class="auth-card" data-aos="zoom-in" data-aos-delay="100" style="margin-top:155px; max-width:740px !important;">
    <div class="text-center mb-4">
        <img src="~/Images/EDOUGLAS ACADEMY LOGO.jpg" alt="site Logo" class="img-fluid mb-3" style="width:80px;">
        <h2 style="color:#53010F;">Create Account</h2>
        <p>Join Edouglas Academy today</p>
    </div>
    <div class="row">
        <i class="fa fa-user-graduate register-icon"></i>

        <!-- Row 1: Surname -->
        <div class="row text-center">
            <div class="mb-3 col-md-12">
                <label>Surname</label>
                <input class="form-control" type="text" id="surname" placeholder="Enter your surname" />
            </div>
        </div>

        <!-- Row 2: First Name & Other Name -->
        <div class="row">
            <div class="mb-3 col-md-6">
                <label>First Name</label>
                <input class="form-control" type="text" id="firstName" />
            </div>
            <div class="mb-3 col-md-6">
                <label>Last Name</label>
                <input class="form-control" type="text" id="lastName" />
            </div>
        </div>

        <!-- Row 3: Email & Phone -->
        <div class="row">
            <div class="mb-3 col-md-6">
                <label>Phone Number</label>
                <input class="form-control" type="text" id="phone" />
            </div>
            <div class="mb-3 col-md-6">
                <label>Email</label>
                <input class="form-control" type="text" id="email" />
            </div>
        </div>
        <!-- Row 4: Password & Confirm Password -->
        <div class="row">
            <div class="mb-3 col-md-6">
                <label>Password</label>
                <div class="pass-group">
                    <input id="password" type="password" class="form-control pass-input" />
                    <span class="ti toggle-password ti-eye-off"></span>
                </div>
            </div>
            <div class="mb-3 col-md-6">
                <label>Confirm Password</label>
                <div class="pass-group">
                    <input id="confirmPassword" type="password" class="form-control pass-inputs" />
                    <span class="ti toggle-passwords ti-eye-off"></span>
                </div>
            </div>
        </div>
        <div class="row">
            <button type="submit" id="submit_btn" style="background-color:#53010F; color:white;" 
                    onclick="registerUser()" class="btn mb-3 text-center">
                Sign Up
            </button>
        </div>
        <p class="text-center mt-4">
            Already have an account? <a asp-action="Login" class="fw-semibold">Login</a>
        </p>
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/js/account.js"></script>
 *@
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Register";
}

<style>
    .auth-page {
        min-height: 100vh;
        background: linear-gradient(rgba(15,23,42,0.92), rgba(21,3,122,0.88));
        display: flex;
        align-items: center;
        position: relative;
    }

    .bg-video {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        z-index: -1;
        filter: brightness(0.6) contrast(1.15);
    }

    .auth-card {
        max-width: 760px;
        margin: 40px auto;
        background: rgba(255,255,255,0.95);
        backdrop-filter: blur(16px);
        border-radius: 24px;
        box-shadow: 0 20px 60px rgba(21,3,122,0.25);
        padding: 40px 35px;
        border: 1px solid rgba(0,212,255,0.2);
    }

        .auth-card h2 {
            font-size: 2.1rem;
            font-weight: 700;
            background: linear-gradient(90deg, #15037A, #00D4FF);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

    .form-control {
        border-radius: 12px;
        padding: 14px 18px;
        border: 2px solid #e2e8f0;
        transition: all 0.3s ease;
    }

        .form-control:focus {
            border-color: #00D4FF;
            box-shadow: 0 0 0 4px rgba(0,212,255,0.15);
        }

    .btn-register {
        background: linear-gradient(90deg, #15037A, #00D4FF);
        border: none;
        border-radius: 50px;
        padding: 16px;
        font-size: 1.15rem;
        font-weight: 600;
        box-shadow: 0 10px 30px rgba(0,212,255,0.4);
    }

        .btn-register:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 35px rgba(0,212,255,0.5);
        }
</style>

<video autoplay muted loop playsinline class="bg-video">
    <source src="~/video/vecteezy_tashkent-uzbekistan-8-4-2022-close-up-of-hands-of-people_42649759.mov" type="video/mp4">
</video>

<div class="auth-page">
    <div class="auth-card" data-aos="zoom-in" data-aos-delay="100">
        <div class="text-center mb-4">
            <img src="~/Images/EDOUGLAS ACADEMY LOGO.jpg" alt="E-Douglas Academy" class="img-fluid mb-3" style="height: 68px;">
            <h2>Join E-Douglas Academy</h2>
            <p class="text-muted">Start your digital skills journey today</p>
        </div>

        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label fw-semibold">Surname</label>
                <input type="text" id="surname" class="form-control" placeholder="Enter surname" />
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold">First Name</label>
                <input type="text" id="firstName" class="form-control" placeholder="Enter first name" />
            </div>

            <div class="col-md-6">
                <label class="form-label fw-semibold">Last Name</label>
                <input type="text" id="lastName" class="form-control" placeholder="Enter last name" />
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold">Phone Number</label>
                <input type="tel" id="phone" class="form-control" placeholder="080xxxxxxxx" />
            </div>

            <div class="col-12">
                <label class="form-label fw-semibold">Email Address</label>
                <input type="email" id="email" class="form-control" placeholder="you@email.com" />
            </div>

            <div class="col-md-6">
                <label class="form-label fw-semibold">Password</label>
                <input type="password" id="password" class="form-control" placeholder="Create password" />
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold">Confirm Password</label>
                <input type="password" id="confirmPassword" class="form-control" placeholder="Confirm password" />
            </div>
        </div>

        <button type="button" id="submit_btn" onclick="registerUser()" class="btn btn-register text-white w-100 mt-4">
            Create My Account
        </button>

        <p class="text-center text-muted mt-4">
            Already have an account?
            <a href="/Account/Login" class="fw-semibold text-primary">Login here →</a>
        </p>
    </div>
</div>