@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Reset Password";
}

<style>
    .auth-page {
        min-height: 100vh;
        background: linear-gradient(rgba(15,23,42,0.92), rgba(21,3,122,0.88));
        display: flex;
        align-items: center;
        position: relative;
    }

    .bg-video {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        z-index: -1;
        filter: brightness(0.6) contrast(1.15);
    }

    .auth-card {
        max-width: 460px;
        margin: 40px auto;
        background: rgba(255,255,255,0.95);
        backdrop-filter: blur(16px);
        border-radius: 24px;
        box-shadow: 0 20px 60px rgba(21,3,122,0.25);
        padding: 40px 35px;
        border: 1px solid rgba(0,212,255,0.2);
    }
</style>

<video autoplay muted loop playsinline class="bg-video">
    <source src="~/video/vecteezy_tashkent-uzbekistan-8-4-2022-close-up-of-hands-of-people_42649759.mov" type="video/mp4">
</video>

<div class="auth-page">
    <div class="auth-card" data-aos="zoom-in">
        <div class="text-center mb-4">
            <img src="~/Images/EDOUGLAS ACADEMY LOGO.jpg" alt="Logo" style="height:68px;" class="mb-3">
            <h2 class="fw-bold">Reset Your Password</h2>
            <p class="text-muted">Enter your new password below</p>
        </div>

        <div class="mb-4">
            <label class="form-label fw-semibold">New Password</label>
            <input type="password" id="newPassword" class="form-control" placeholder="••••••••" required />
        </div>

        <div class="mb-4">
            <label class="form-label fw-semibold">Confirm New Password</label>
            <input type="password" id="confirmPassword" class="form-control" placeholder="••••••••" required />
        </div>

        <button onclick="resetPassword()" class="btn w-100 btn-magic text-white py-3">
            Reset Password
        </button>

        <p class="text-center mt-4">
            <a href="/Account/Login" class="text-primary fw-semibold">← Back to Login</a>
        </p>
    </div>
</div>

<script>
    function resetPassword() {
        successAlertWithRedirect("Your password has been reset successfully!", "/Account/Login");
    }
</script>
