@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Admin Dashboard";
}

<style>
    .admin-page {
        background: #0f172a;
        color: #f8fafc;
        min-height: calc(100vh - 110px);
        padding: 40px 0;
    }

    .stat-card {
        background: #1e2937;
        border-radius: 20px;
        padding: 28px;
        transition: all 0.4s ease;
        border: 1px solid rgba(0, 212, 255, 0.15);
    }

        .stat-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 40px rgba(0, 212, 255, 0.25);
        }

    .stat-value {
        font-size: 2.8rem;
        font-weight: 700;
        background: linear-gradient(90deg, #00D4FF, #ffffff);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .table-container {
        background: #1e2937;
        border-radius: 20px;
        overflow: hidden;
    }

    .admin-header {
        background: linear-gradient(90deg, #15037A, #00D4FF);
        color: white;
        padding: 30px 40px;
        border-radius: 20px;
        margin-bottom: 40px;
    }

    .quick-btn {
        background: rgba(255,255,255,0.1);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(0,212,255,0.3);
        color: white;
        border-radius: 50px;
        padding: 14px 28px;
        transition: all 0.3s ease;
    }

        .quick-btn:hover {
            background: #00D4FF;
            color: #0f172a;
            transform: translateY(-3px);
        }
</style>

<div class="admin-page">
    <div class="container">

        <!-- Header -->
        <div class="admin-header d-flex justify-content-between align-items-center">
            <div>
                <h1 class="display-5 fw-bold mb-1">Admin Dashboard</h1>
                <p class="mb-0 opacity-90">Welcome back, Admin • Real-time overview of E-Douglas Academy</p>
            </div>
            <div class="text-end">
                <button onclick="refreshDashboard()" class="quick-btn">
                    <i class="bi bi-arrow-clockwise"></i> Refresh Data
                </button>
            </div>
        </div>

        <!-- Stats Row -->
        <div class="row g-4 mb-5">
            <div class="col-xl-3 col-md-6" data-aos="fade-up" data-aos-delay="100">
                <div class="stat-card text-center">
                    <i class="bi bi-people-fill fs-1 text-info mb-3"></i>
                    <div class="stat-value" id="totalStudents">248</div>
                    <p class="mb-0 text-light">Total Students</p>
                    <small class="text-success">+18 this week</small>
                </div>
            </div>
            <div class="col-xl-3 col-md-6" data-aos="fade-up" data-aos-delay="200">
                <div class="stat-card text-center">
                    <i class="bi bi-book-fill fs-1 text-primary mb-3"></i>
                    <div class="stat-value" id="totalCourses">12</div>
                    <p class="mb-0 text-light">Active Courses</p>
                    <small class="text-success">2 new this month</small>
                </div>
            </div>
            <div class="col-xl-3 col-md-6" data-aos="fade-up" data-aos-delay="300">
                <div class="stat-card text-center">
                    <i class="bi bi-currency-naira fs-1 text-success mb-3"></i>
                    <div class="stat-value" id="totalRevenue">₦4.8M</div>
                    <p class="mb-0 text-light">Revenue This Month</p>
                    <small class="text-success">↑ 24%</small>
                </div>
            </div>
            <div class="col-xl-3 col-md-6" data-aos="fade-up" data-aos-delay="400">
                <div class="stat-card text-center">
                    <i class="bi bi-award-fill fs-1 text-warning mb-3"></i>
                    <div class="stat-value" id="certificatesIssued">87</div>
                    <p class="mb-0 text-light">Certificates Issued</p>
                    <small class="text-muted">This quarter</small>
                </div>
            </div>
        </div>

        <div class="row g-4">

            <!-- Recent Enrollments -->
            <div class="col-lg-7">
                <div class="table-container p-4">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h4 class="fw-semibold mb-0">Recent Enrollments</h4>
                        <a href="/Admin/Enrollments" class="text-info">View All →</a>
                    </div>
                    <table class="table table-dark table-hover align-middle">
                        <thead>
                            <tr>
                                <th>Student</th>
                                <th>Course</th>
                                <th>Date</th>
                                <th>Amount</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody id="enrollmentsTable">
                            <!-- Populated by JS -->
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Quick Actions -->
            <div class="col-lg-5">
                <div class="bg-[#1e2937] rounded-4 p-5 h-100">
                    <h4 class="fw-semibold mb-4">Quick Actions</h4>

                    <div class="d-grid gap-3">
                        <a href="/Course/Create" class="btn quick-btn text-start fs-5">
                            <i class="bi bi-plus-circle me-3"></i> Create New Course
                        </a>
                        <a href="/Admin/Students" class="btn quick-btn text-start fs-5">
                            <i class="bi bi-person-plus me-3"></i> Add New Student
                        </a>
                        <a href="/Admin/Approvals" class="btn quick-btn text-start fs-5">
                            <i class="bi bi-check-circle me-3"></i> Review Certificate Requests
                        </a>
                        <a href="/Admin/Enrollments" class="btn quick-btn text-start fs-5">
                            <i class="bi bi-list-check me-3"></i> Manage Enrollments
                        </a>
                    </div>

                    <div class="mt-5 pt-5 border-top text-center">
                        <small class="text-light">Need help? Contact super admin</small>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<script>
    // Sample recent enrollments
    const recentEnrollments = [
        { student: "Blessing Okorie", course: "Web Design Fundamentals", date: "Mar 24", amount: "₦85,000", status: "Paid" },
        { student: "Samuel Ade", course: "Microsoft Office Mastery", date: "Mar 23", amount: "₦65,000", status: "Paid" },
        { student: "Abdul Musa", course: "Digital Marketing", date: "Mar 22", amount: "₦95,000", status: "Pending" },
        { student: "Peace Johnson", course: "Computer Basics", date: "Mar 21", amount: "₦45,000", status: "Paid" }
    ];

    function renderEnrollments() {
        const tbody = document.getElementById('enrollmentsTable');
        tbody.innerHTML = recentEnrollments.map(item => `
            <tr>
                <td><strong>${item.student}</strong></td>
                <td>${item.course}</td>
                <td>${item.date}</td>
                <td>${item.amount}</td>
                <td><span class="badge ${item.status === 'Paid' ? 'bg-success' : 'bg-warning'}">${item.status}</span></td>
            </tr>
        `).join('');
    }

    function refreshDashboard() {
        successAlert("Dashboard data refreshed!");
        // You can later add real API calls here
        setTimeout(() => renderEnrollments(), 600);
    }

    // Initialize
    window.onload = renderEnrollments;
</script>