@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Dashboard";
}

<div class="page-wrapper">
    <div class="d-md-flex d-block align-items-center justify-content-between page-breadcrumb mb-3">
        <div class="my-auto mb-2">
            <h2 class="mb-1">Admin Dashboard</h2>
            <nav>
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item">
                        <a href="javascript:void(0);"><i class="ti ti-smart-home"></i></a>
                    </li>
                    <li class="breadcrumb-item">Dashboard</li>
                </ol>
            </nav>
        </div>
    </div>

    <!-- Welcome Card -->
    <div class="card mb-3">
        <div class="card-body d-flex align-items-center justify-content-between flex-wrap pb-1">
            <div class="d-flex align-items-center mb-3">
                <span class="avatar avatar-xl flex-shrink-0">
                    <img src="~/Templates/assets/img/profiles/avatar-31.jpg" class="rounded-circle" alt="img">
                </span>
                <div class="ms-3">
                    <h3 class="mb-2">
                        Welcome Back, @Model.UserName
                        <a href="javascript:void(0);" class="edit-icon">
                            <i class="ti ti-edit fs-14"></i>
                        </a>
                    </h3>
                    <p>
                        You have
                        <span class="text-primary text-decoration-underline">@Model.ActiveCourses</span> Active Courses
                        &
                        <span class="text-primary text-decoration-underline">@Model.TotalStudents</span> Enrolled Students
                    </p>
                </div>
            </div>
            <div class="d-flex align-items-center flex-wrap mb-1">
                <a href="#" class="btn btn-secondary btn-md me-2 mb-2"
                   data-bs-toggle="modal" data-bs-target="#add_course">
                    <i class="ti ti-square-rounded-plus me-1"></i>Add Course
                </a>
                <a href="#" class="btn btn-primary btn-md mb-2"
                   data-bs-toggle="modal" data-bs-target="#add_student">
                    <i class="ti ti-square-rounded-plus me-1"></i>Add Student
                </a>
            </div>
        </div>
    </div>

    <!-- Stats Cards -->
    <div class="row">
        <div class="row flex-fill">

            <!-- Total Students -->
            <div class="col-md-3 d-flex">
                <div class="card flex-fill">
                    <div class="card-body">
                        <span class="avatar rounded-circle bg-info mb-2">
                            <i class="ti ti-users-group fs-16"></i>
                        </span>
                        <h6 class="fs-13 fw-medium text-default mb-1">Total Students</h6>
                        <h3 class="mb-3">@Model.TotalStudents</h3>
                        <a asp-controller="Admin" asp-action="Students" class="link-default">View All</a>
                    </div>
                </div>
            </div>

            <!-- Active Courses -->
            <div class="col-md-3 d-flex">
                <div class="card flex-fill">
                    <div class="card-body">
                        <span class="avatar rounded-circle bg-secondary mb-2">
                            <i class="ti ti-browser fs-16"></i>
                        </span>
                        <h6 class="fs-13 fw-medium text-default mb-1">Active Courses</h6>
                        <h3 class="mb-3">@Model.ActiveCourses</h3>
                        <a asp-action="Index" asp-controller="Course" class="link-default">View All</a>
                    </div>
                </div>
            </div>

            <!-- Certificates Issued -->
            <div class="col-md-3 d-flex">
                <div class="card flex-fill">
                    <div class="card-body">
                        <span class="avatar rounded-circle bg-success mb-2">
                            <i class="ti ti-award fs-16"></i>
                        </span>
                        <h6 class="fs-13 fw-medium text-default mb-1">Certificates Issued</h6>
                        <h3 class="mb-3">@Model.CertificatesIssued</h3>
                        <a asp-controller="Admin" asp-action="Approvals" class="link-default">View All</a>
                    </div>
                </div>
            </div>

            <!-- Revenue -->
            <div class="col-md-3 d-flex">
                <div class="card flex-fill">
                    <div class="card-body">
                        <span class="avatar rounded-circle bg-purple mb-2">
                            <i class="ti ti-moneybag fs-16"></i>
                        </span>
                        <h6 class="fs-13 fw-medium text-default mb-1">Revenue This Month</h6>
                        <h3 class="mb-3">₦@Model.TotalEarnings.ToString("N0")</h3>
                        <a asp-controller="Admin" asp-action="Enrollments" class="link-default">View All</a>
                    </div>
                </div>
            </div>

        </div>
    </div>
    @await Html.PartialAsync("_CreateCourseModal")
    @await Html.PartialAsync("_AddStudentModal")
</div>