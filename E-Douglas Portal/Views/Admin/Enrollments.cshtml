@using Core.ViewModels
@using X.PagedList.Mvc.Core
@model Core.ViewModels.IPageListModel<EnrollmentListViewModel>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Enrollments";
}

<div class="page-wrapper">
    <div class="content">
        <div class="d-md-flex d-block align-items-center justify-content-between page-breadcrumb mb-3">
            <div class="my-auto mb-2">
                <h2 class="mb-1">Enrollments</h2>
                <nav>
                    <ol class="breadcrumb mb-0">
                        <li class="breadcrumb-item"><a href="javascript:void(0);"><i class="ti ti-smart-home"></i></a></li>
                        <li class="breadcrumb-item">Dashboard</li>
                        <li class="breadcrumb-item active" aria-current="page">Enrollments</li>
                    </ol>
                </nav>
            </div>
        </div>

        @Html.Partial("_PageSearcher", Model)

        <div class="card-box">
            <div class="table-responsive">
                <table class="table table-striped">
                    <thead class="thead-light">
                        <tr>
                            <th>Student</th>
                            <th>Course</th>
                            <th>Date</th>
                            <th>Amount</th>
                            <th>Payment Status</th>
                            <th>Reference</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model?.Model != null && Model.Model.Any())
                        {
                            @foreach (var e in Model.Model)
                            {
                                <tr>
                                    <td>@e.StudentName</td>
                                    <td>@e.CourseName</td>
                                    <td>@e.DateCreated.ToString("dd MMM yyyy")</td>
                                    <td>₦@e.Amount.ToString("N0")</td>
                                    <td>
                                        <span class="badge @(e.PaymentStatus == "Paid" ? "bg-success" : e.PaymentStatus == "Failed" ? "bg-danger" : "bg-warning")">
                                            @e.PaymentStatus
                                        </span>
                                    </td>
                                    <td><small class="text-muted">@(e.PaymentReference ?? "—")</small></td>
                                    <td>
                                        <button class="btn btn-sm btn-outline-secondary" disabled title="Coming with the payment verification feature">View</button>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="7" class="text-center text-muted py-4">No enrollments yet.</td></tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (Model?.Model != null)
            {
                <div class="mt-3">
                    @Html.PagedListPager(Model.Model, page => Url.Action("Enrollments", "Admin", new { page, Keyword = Model.Keyword, StartDate = Model.StartDate, EndDate = Model.EndDate }))
                </div>
            }
        </div>
    </div>
</div>