@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Enrollments";
}

<style>
    .admin-page {
        background: #0f172a;
        color: #f8fafc;
        min-height: calc(100vh - 110px);
        padding: 40px 0;
    }

    .table-container {
        background: #1e2937;
        border-radius: 24px;
        overflow: hidden;
        box-shadow: 0 10px 40px rgba(0, 212, 255, 0.15);
    }

    .table thead {
        background: #15037A;
        color: white;
    }

    .enrollment-row:hover {
        background: #334155 !important;
    }

    .status-paid {
        background: #10B981;
        color: white;
    }

    .status-pending {
        background: #f59e0b;
        color: white;
    }

    .status-failed {
        background: #ef4444;
        color: white;
    }

    .search-box {
        border-radius: 50px;
        background: #1e2937;
        border: 2px solid #00D4FF;
        color: white;
    }
</style>

<div class="admin-page">
    <div class="container">

        <div class="d-flex justify-content-between align-items-center mb-5">
            <div>
                <h1 class="display-5 fw-bold mb-1">All Enrollments</h1>
                <p class="text-light lead mb-0">Track payments &amp; enrollments • <span id="totalEnrollments">142</span> total</p>
            </div>

            <div class="d-flex gap-3 align-items-center">
                <input type="text" id="searchInput" placeholder="Search student or course..."
                       class="form-control search-box" style="max-width: 340px;" onkeyup="filterEnrollments()">

                <div class="btn-group">
                    <button onclick="filterStatus('all')" class="btn btn-outline-light active" id="filter-all">All</button>
                    <button onclick="filterStatus('paid')" class="btn btn-outline-light" id="filter-paid">Paid</button>
                    <button onclick="filterStatus('pending')" class="btn btn-outline-light" id="filter-pending">Pending</button>
                    <button onclick="filterStatus('failed')" class="btn btn-outline-light" id="filter-failed">Failed</button>
                </div>
            </div>
        </div>

        <div class="table-container p-4">
            <table class="table table-dark table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Student</th>
                        <th>Course</th>
                        <th>Enrollment Date</th>
                        <th>Amount</th>
                        <th>Payment Status</th>
                        <th>Reference</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody id="enrollmentsTable">
                    <!-- Populated by JavaScript -->
                </tbody>
            </table>
        </div>

    </div>
</div>

<script>
    // Sample enrollments data
    let allEnrollments = [
        {
            id: 1,
            student: "Blessing Okorie",
            course: "Web Design Fundamentals",
            date: "Mar 24, 2026",
            amount: "₦85,000",
            status: "paid",
            reference: "ED-REF-7843921"
        },
        {
            id: 2,
            student: "Samuel Ade",
            course: "Microsoft Office Mastery",
            date: "Mar 23, 2026",
            amount: "₦65,000",
            status: "paid",
            reference: "ED-REF-7843922"
        },
        {
            id: 3,
            student: "Abdul Musa",
            course: "Digital Marketing Essentials",
            date: "Mar 22, 2026",
            amount: "₦95,000",
            status: "pending",
            reference: "ED-REF-7843923"
        },
        {
            id: 4,
            student: "Peace Johnson",
            course: "Computer Appreciation",
            date: "Mar 21, 2026",
            amount: "₦45,000",
            status: "failed",
            reference: "ED-REF-7843924"
        }
    ];

    function renderEnrollments(enrollments) {
        const tbody = document.getElementById('enrollmentsTable');
        tbody.innerHTML = enrollments.map(en => `
            <tr class="enrollment-row">
                <td><strong>${en.student}</strong></td>
                <td>${en.course}</td>
                <td>${en.date}</td>
                <td class="fw-semibold">${en.amount}</td>
                <td>
                    <span class="status-badge px-4 py-1 rounded-pill ${en.status === 'paid' ? 'status-paid' : en.status === 'pending' ? 'status-pending' : 'status-failed'}">
                        ${en.status.toUpperCase()}
                    </span>
                </td>
                <td><small class="text-info">${en.reference}</small></td>
                <td>
                    <button onclick="viewPaymentDetails(${en.id})" class="btn btn-sm btn-outline-info">View</button>
                </td>
            </tr>
        `).join('');

        document.getElementById('totalEnrollments').textContent = enrollments.length;
    }

    function filterStatus(status) {
        document.querySelectorAll('.btn-group button').forEach(btn => btn.classList.remove('active'));

        if (status === 'all') {
            document.getElementById('filter-all').classList.add('active');
            renderEnrollments(allEnrollments);
        } else {
            document.getElementById('filter-' + status).classList.add('active');
            const filtered = allEnrollments.filter(e => e.status === status);
            renderEnrollments(filtered);
        }
    }

    function filterEnrollments() {
        const term = document.getElementById('searchInput').value.toLowerCase().trim();
        if (!term) {
            renderEnrollments(allEnrollments);
            return;
        }
        const filtered = allEnrollments.filter(e =>
            e.student.toLowerCase().includes(term) ||
            e.course.toLowerCase().includes(term)
        );
        renderEnrollments(filtered);
    }

    function viewPaymentDetails(id) {
        successAlertWithRedirect("Opening payment details for enrollment #" + id, "/Payment/Checkout/" + id);
    }

    // Initial render
    window.onload = () => renderEnrollments(allEnrollments);
</script>
