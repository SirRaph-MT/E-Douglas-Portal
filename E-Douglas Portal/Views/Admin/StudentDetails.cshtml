@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Student Details";
}

<style>
    .admin-page {
        background: #0f172a;
        color: #f8fafc;
        min-height: calc(100vh - 110px);
        padding: 40px 0;
    }

    .profile-header {
        background: linear-gradient(90deg, #15037A, #00D4FF);
        border-radius: 24px;
        padding: 40px;
        color: white;
        margin-bottom: 30px;
    }

    .info-card {
        background: #1e2937;
        border-radius: 20px;
        padding: 28px;
        box-shadow: 0 10px 30px rgba(0, 212, 255, 0.15);
    }

    .course-progress-card {
        background: #1e2937;
        border-radius: 20px;
        padding: 24px;
        transition: all 0.3s ease;
    }

        .course-progress-card:hover {
            transform: translateY(-6px);
        }

    .action-btn {
        border-radius: 50px;
        padding: 12px 28px;
        font-weight: 600;
    }
</style>

<div class="admin-page">
    <div class="container">

        <!-- Back & Header -->
        <a href="/Admin/Students" class="text-info mb-3 d-inline-block">← Back to All Students</a>

        <div class="profile-header d-flex align-items-center">
            <div class="flex-grow-1">
                <h1 class="display-5 fw-bold mb-1" id="studentName">Blessing Okorie</h1>
                <p class="mb-0" id="studentEmail">blessing.okorie@gmail.com</p>
                <p class="mb-0 opacity-75" id="studentPhone">+234 811 537 9302</p>
            </div>
            <div class="text-end">
                <span class="badge bg-success fs-5 px-4 py-2">Active Student</span>
            </div>
        </div>

        <div class="row g-4">

            <!-- Left Column: Info -->
            <div class="col-lg-4">
                <div class="info-card h-100">
                    <h4 class="fw-semibold mb-4">Profile Information</h4>
                    <div class="mb-4">
                        <strong>Date of Birth:</strong> <span id="dob">15 March 2002</span><br>
                        <strong>Student Type:</strong> <span id="studentType">Full-Time</span><br>
                        <strong>Sponsor:</strong> <span id="sponsor">Mr. Chukwudi Okorie</span>
                    </div>

                    <div class="mt-auto pt-4 border-top">
                        <h5 class="text-info mb-3">Quick Actions</h5>
                        <div class="d-grid gap-2">
                            <button onclick="editStudent()" class="btn btn-outline-info action-btn">
                                <i class="bi bi-pencil"></i> Edit Profile
                            </button>
                            <button onclick="suspendStudent()" class="btn btn-outline-warning action-btn">
                                <i class="bi bi-pause-circle"></i> Suspend Account
                            </button>
                            <button onclick="deleteStudent()" class="btn btn-outline-danger action-btn">
                                <i class="bi bi-trash"></i> Delete Student
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Column: Enrolled Courses & Progress -->
            <div class="col-lg-8">
                <h4 class="fw-semibold mb-4">Enrolled Courses &amp; Progress</h4>
                <div class="row g-4" id="enrolledCoursesContainer">
                    <!-- Populated by JavaScript -->
                </div>
            </div>

        </div>

        <!-- Activity Timeline -->
        <div class="mt-5">
            <h4 class="fw-semibold mb-4">Recent Activity</h4>
            <div class="info-card">
                <ul class="list-unstyled" id="activityList">
                    <!-- Populated by JavaScript -->
                </ul>
            </div>
        </div>

    </div>
</div>

<script>
    // Sample data for this student
    const studentData = {
        name: "Blessing Okorie",
        email: "blessing.okorie@gmail.com",
        phone: "+234 811 537 9302",
        dob: "15 March 2002",
        studentType: "Full-Time",
        sponsor: "Mr. Chukwudi Okorie"
    };

    const enrolledCourses = [
        { title: "Web Design Fundamentals", progress: 92, status: "In Progress" },
        { title: "Digital Marketing Essentials", progress: 65, status: "In Progress" }
    ];

    const activity = [
        { date: "Mar 24, 2026", action: "Completed Module 4 in Web Design" },
        { date: "Mar 22, 2026", action: "Enrolled in Digital Marketing Essentials" },
        { date: "Mar 18, 2026", action: "Submitted assignment for CSS Grid" }
    ];

    function renderEnrolledCourses() {
        const container = document.getElementById('enrolledCoursesContainer');
        container.innerHTML = enrolledCourses.map(course => `
            <div class="col-md-6">
                <div class="course-progress-card">
                    <h5>${course.title}</h5>
                    <div class="d-flex justify-content-between mb-2">
                        <span>Progress</span>
                        <strong>${course.progress}%</strong>
                    </div>
                    <div class="progress-bar bg-secondary rounded-pill" style="height:12px">
                        <div class="progress-fill" style="width:${course.progress}%; background: linear-gradient(90deg, #00D4FF, #15037A);"></div>
                    </div>
                    <small class="text-info mt-2 d-block">${course.status}</small>
                </div>
            </div>
        `).join('');
    }

    function renderActivity() {
        const list = document.getElementById('activityList');
        list.innerHTML = activity.map(item => `
            <li class="d-flex justify-content-between py-3 border-bottom">
                <span>${item.action}</span>
                <small class="text-muted">${item.date}</small>
            </li>
        `).join('');
    }

    // Fake action alerts
    function editStudent() { successAlert("Student profile edit form would open here"); }
    function suspendStudent() { successAlert("Student account has been suspended"); }
    function deleteStudent() {
        if (confirm("Delete this student permanently?")) {
            successAlert("Student deleted successfully");
        }
    }

    // Initialize page
    window.onload = () => {
        document.getElementById('studentName').textContent = studentData.name;
        document.getElementById('studentEmail').textContent = studentData.email;
        document.getElementById('studentPhone').textContent = studentData.phone;
        document.getElementById('dob').textContent = studentData.dob;
        document.getElementById('studentType').textContent = studentData.studentType;
        document.getElementById('sponsor').textContent = studentData.sponsor;

        renderEnrolledCourses();
        renderActivity();
    };
</script>
