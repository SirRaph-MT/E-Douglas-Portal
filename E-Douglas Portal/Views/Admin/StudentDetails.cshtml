@model Core.ViewModels.StudentDetailsViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Student Details";
}

<div class="page-wrapper">
    <div class="content">

        <a href="/Admin/Students" class="text-muted small mb-3 d-inline-block">← Back to All Students</a>

        <div class="card mb-3">
            <div class="card-body d-flex align-items-center justify-content-between flex-wrap">
                <div>
                    <h3 class="mb-1">@Model.FullName</h3>
                    <p class="mb-0 text-muted">@Model.Email</p>
                    <p class="mb-0 text-muted">@Model.PhoneNumber</p>
                </div>
                <span class="badge @(Model.Deleted ? "bg-danger" : "bg-success") fs-6 px-3 py-2">
                    @(Model.Deleted ? "Inactive" : "Active")
                </span>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-lg-4">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="mb-3">Profile Information</h5>
                        <p class="mb-1"><strong>Date of Birth:</strong> @(Model.DateOfBirth?.ToString("dd MMM yyyy") ?? "Not set")</p>
                        <p class="mb-1"><strong>Student Type:</strong> @(Model.StudentType ?? "Not set")</p>
                        <p class="mb-1"><strong>Sponsor:</strong> @(Model.SponsorName ?? "Not set")</p>
                        <p class="mb-3"><strong>Sponsor Phone:</strong> @(Model.SponsorPhone ?? "Not set")</p>

                        <div class="pt-3 border-top">
                            <h6 class="text-muted mb-2">Quick Actions</h6>
                            <div class="d-grid gap-2">
                                <button class="btn btn-outline-secondary" disabled title="Coming soon">
                                    <i class="ti ti-pencil"></i> Edit Profile
                                </button>
                                <button class="btn btn-outline-secondary" disabled title="Coming soon">
                                    <i class="ti ti-pause"></i> Suspend Account
                                </button>
                            </div>
                            <small class="text-muted d-block mt-2">Suspend / edit actions aren't wired up yet — next feature.</small>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-8">
                <h5 class="mb-3">Enrolled Courses &amp; Progress</h5>
                @if (!Model.EnrolledCourses.Any())
                {
                    <div class="card"><div class="card-body text-muted text-center py-4">No enrollments yet.</div></div>
                }
                else
                {
                    <div class="row g-3">
                        @foreach (var course in Model.EnrolledCourses)
                        {
                            <div class="col-md-6">
                                <div class="card h-100">
                                    <div class="card-body">
                                        <h6>@course.CourseTitle</h6>
                                        <div class="d-flex justify-content-between mb-1">
                                            <span>Progress</span>
                                            <strong>@course.ProgressPercentage%</strong>
                                        </div>
                                        <div class="progress" style="height:10px">
                                            <div class="progress-bar" style="width:@course.ProgressPercentage%"></div>
                                        </div>
                                        <small class="text-muted d-block mt-2">@course.EnrollmentStatus</small>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>

    </div>
</div>