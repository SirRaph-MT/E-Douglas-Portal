@using Core.ViewModels
@using X.PagedList.Mvc.Core
@model Core.ViewModels.IPageListModel<ApplicationUserViewModel>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Students";
}

<style>
    body {
        counter-reset: Serial;
    }

    tr td:first-child:before {
        counter-increment: Serial;
        content: counter(Serial);
    }
</style>

<div class="page-wrapper">
    <div class="content">
        <div class="d-md-flex d-block align-items-center justify-content-between page-breadcrumb mb-3">
            <div class="my-auto mb-2">
                <h2 class="mb-1">Students</h2>
                <nav>
                    <ol class="breadcrumb mb-0">
                        <li class="breadcrumb-item"><a href="javascript:void(0);"><i class="ti ti-smart-home"></i></a></li>
                        <li class="breadcrumb-item">Dashboard</li>
                        <li class="breadcrumb-item active" aria-current="page">Students</li>
                    </ol>
                </nav>
            </div>
        </div>

        @Html.Partial("_PageSearcher", Model)

        <div class="card-box">
            <div class="col-md-12">
                <div class="table-responsive">
                    <table class="table table-striped">
                        <thead class="thead-light">
                            <tr>
                                <th>S/N</th>
                                <th>Full Name</th>
                                <th>Email</th>
                                <th>Phone Number</th>
                                <th>Date Joined</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model?.Model != null && Model.Model.Any())
                            {
                                @foreach (var student in Model.Model)
                                {
                                    <tr>
                                        <td></td>
                                        <td>@student.FullName</td>
                                        <td>@student.Email</td>
                                        <td>@student.PhoneNumber</td>
                                        <td>@student.DateRegistered?.ToString("dd/MMM/yyyy")</td>
                                        <td>
                                            <a href="/Admin/StudentDetails/@student.Id" class="btn btn-sm btn-outline-info">
                                                View Details
                                            </a>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr><td colspan="6" class="text-center text-muted py-4">No students found.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if (Model?.Model != null)
                {
                    <div class="mt-3">
                        @Html.PagedListPager(Model.Model, page => Url.Action("Students", "Admin", new { page, Keyword = Model.Keyword, StartDate = Model.StartDate, EndDate = Model.EndDate }))
                    </div>
                }
            </div>
        </div>
    </div>
</div>