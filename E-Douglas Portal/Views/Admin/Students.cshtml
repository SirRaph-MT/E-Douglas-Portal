@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "All Students";
}

<style>
    .admin-page {
        background: #0f172a;
        color: #f8fafc;
        min-height: calc(100vh - 110px);
        padding: 40px 0;
    }

    .table-container {
        background: #1e2937;
        border-radius: 24px;
        overflow: hidden;
        box-shadow: 0 10px 40px rgba(0, 212, 255, 0.15);
    }

    .table thead {
        background: #15037A;
        color: white;
    }

    .student-row:hover {
        background: #334155 !important;
        transform: scale(1.02);
        transition: all 0.3s ease;
    }

    .status-badge {
        padding: 6px 16px;
        border-radius: 50px;
        font-size: 0.85rem;
    }

    .search-box {
        border-radius: 50px;
        background: #1e2937;
        border: 2px solid #00D4FF;
        color: white;
    }
</style>

<div class="admin-page">
    <div class="container">

        <div class="d-flex justify-content-between align-items-center mb-5">
            <div>
                <h1 class="display-5 fw-bold mb-1">All Students</h1>
                <p class="text-light lead mb-0">Manage enrolled students • <span id="totalCount">248</span> total</p>
            </div>

            <div class="d-flex gap-3">
                <input type="text" id="searchInput" placeholder="Search by name or email..."
                       class="form-control search-box w-100" style="max-width: 380px;" onkeyup="filterStudents()">

                <a href="/Admin/StudentDetails/0" class="btn btn-light px-5 py-3 fw-semibold">
                    <i class="bi bi-person-plus"></i> Add New Student
                </a>
            </div>
        </div>

        <div class="table-container p-4">
            <table class="table table-dark table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Student</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>Course(s)</th>
                        <th>Progress</th>
                        <th>Status</th>
                        <th>Joined</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody id="studentsTable">
                    <!-- Populated by JavaScript -->
                </tbody>
            </table>
        </div>

    </div>
</div>

<script>
    // Sample students data (replace later with real backend data)
    let allStudents = [
        {
            id: 1,
            name: "Blessing Okorie",
            email: "blessing.okorie@gmail.com",
            phone: "+234 811 537 9302",
            courses: "Web Design, Digital Marketing",
            progress: "92%",
            status: "Active",
            joined: "Feb 12, 2026"
        },
        {
            id: 2,
            name: "Samuel Ade",
            email: "samuel.ade@yahoo.com",
            phone: "+234 816 225 7343",
            courses: "Microsoft Office",
            progress: "65%",
            status: "Active",
            joined: "Mar 01, 2026"
        },
        {
            id: 3,
            name: "Abdul Musa",
            email: "abdul.musa@outlook.com",
            phone: "+234 703 533 4235",
            courses: "Computer Basics",
            progress: "100%",
            status: "Graduated",
            joined: "Jan 15, 2026"
        },
        {
            id: 4,
            name: "Peace Johnson",
            email: "peace.johnson@gmail.com",
            phone: "+234 811 537 9302",
            courses: "Web Design",
            progress: "40%",
            status: "Active",
            joined: "Mar 20, 2026"
        }
    ];

    function renderStudents(students) {
        const tbody = document.getElementById('studentsTable');
        tbody.innerHTML = students.map(student => `
            <tr class="student-row">
                <td><strong>${student.name}</strong></td>
                <td>${student.email}</td>
                <td>${student.phone}</td>
                <td><small class="text-info">${student.courses}</small></td>
                <td><strong>${student.progress}</strong></td>
                <td>
                    <span class="status-badge ${student.status === 'Active' ? 'bg-success' : 'bg-warning'}">
                        ${student.status}
                    </span>
                </td>
                <td>${student.joined}</td>
                <td>
                    <a href="/Admin/StudentDetails/${student.id}" class="btn btn-sm btn-outline-info">
                        View Details
                    </a>
                </td>
            </tr>
        `).join('');

        document.getElementById('totalCount').textContent = students.length;
    }

    function filterStudents() {
        const term = document.getElementById('searchInput').value.toLowerCase().trim();
        if (!term) {
            renderStudents(allStudents);
            return;
        }
        const filtered = allStudents.filter(s =>
            s.name.toLowerCase().includes(term) ||
            s.email.toLowerCase().includes(term)
        );
        renderStudents(filtered);
    }

    // Initial render
    window.onload = () => renderStudents(allStudents);
</script>