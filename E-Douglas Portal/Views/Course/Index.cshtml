@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Manage Courses";
}

<style>
    .admin-page {
        background: #0f172a;
        color: #f8fafc;
        min-height: calc(100vh - 110px);
        padding: 40px 0;
    }

    .table-container {
        background: #1e2937;
        border-radius: 24px;
        overflow: hidden;
        box-shadow: 0 10px 40px rgba(0, 212, 255, 0.15);
    }

    .table thead {
        background: #15037A;
        color: white;
    }

    .course-row:hover {
        background: #334155 !important;
        transition: all 0.3s ease;
    }

    .search-box {
        border-radius: 50px;
        background: #1e2937;
        border: 2px solid #00D4FF;
        color: white;
    }

    .btn-add {
        background: linear-gradient(90deg, #15037A, #00D4FF);
        border: none;
        border-radius: 50px;
        padding: 12px 32px;
        font-weight: 600;
    }
</style>

<div class="admin-page">
    <div class="container">

        <div class="d-flex justify-content-between align-items-center mb-5">
            <div>
                <h1 class="display-5 fw-bold mb-1">Manage Courses</h1>
                <p class="text-light lead mb-0">All available courses • <span id="totalCourses">12</span> total</p>
            </div>

            <div class="d-flex gap-3">
                <input type="text" id="searchInput" placeholder="Search courses..."
                       class="form-control search-box" style="max-width: 340px;" onkeyup="filterCourses()">

                <a href="/Course/Create" class="btn btn-add text-white">
                    <i class="bi bi-plus-circle"></i> Create New Course
                </a>
            </div>
        </div>

        <div class="table-container p-4">
            <table class="table table-dark table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Course Title</th>
                        <th>Duration</th>
                        <th>Price</th>
                        <th>Students Enrolled</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="coursesTable">
                    <!-- Populated by JavaScript -->
                </tbody>
            </table>
        </div>

    </div>
</div>

<script>
    // Sample courses data (replace later with real data from controller)
    let allCourses = [
        {
            id: 1,
            title: "Web Design Fundamentals",
            duration: "8 Weeks",
            price: "₦85,000",
            enrolled: 47,
            status: "Active"
        },
        {
            id: 2,
            title: "Microsoft Office Mastery",
            duration: "6 Weeks",
            price: "₦65,000",
            enrolled: 63,
            status: "Active"
        },
        {
            id: 3,
            title: "Digital Marketing Essentials",
            duration: "10 Weeks",
            price: "₦95,000",
            enrolled: 29,
            status: "Active"
        },
        {
            id: 4,
            title: "Computer Appreciation & Basics",
            duration: "4 Weeks",
            price: "₦45,000",
            enrolled: 81,
            status: "Active"
        }
    ];

    function renderCourses(courses) {
        const tbody = document.getElementById('coursesTable');
        tbody.innerHTML = courses.map(course => `
            <tr class="course-row">
                <td><strong>${course.title}</strong></td>
                <td>${course.duration}</td>
                <td class="fw-semibold">${course.price}</td>
                <td>${course.enrolled} students</td>
                <td><span class="badge bg-success">${course.status}</span></td>
                <td>
                    <a href="/Course/Edit/${course.id}" class="btn btn-sm btn-outline-info me-2">Edit</a>
                    <button onclick="deleteCourse(${course.id})" class="btn btn-sm btn-outline-danger">Delete</button>
                </td>
            </tr>
        `).join('');

        document.getElementById('totalCourses').textContent = courses.length;
    }

    function filterCourses() {
        const term = document.getElementById('searchInput').value.toLowerCase().trim();
        if (!term) {
            renderCourses(allCourses);
            return;
        }
        const filtered = allCourses.filter(c => c.title.toLowerCase().includes(term));
        renderCourses(filtered);
    }

    function deleteCourse(id) {
        if (confirm("Delete this course permanently?")) {
            successAlert("Course deleted successfully");
            allCourses = allCourses.filter(c => c.id !== id);
            renderCourses(allCourses);
        }
    }

    // Initial render
    window.onload = () => renderCourses(allCourses);
</script>
