@model Core.Models.Course
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Course Details";
}
<!-- ...styles unchanged... -->

<h1 class="display-4 fw-bold" id="courseTitle">@Model.Title</h1>
<p class="lead mb-0" id="courseSubtitle">@Model.Description</p>

<!-- ...inside the price badge... -->
<span class="price-badge">₦@Model.Price?.ToString("N0")</span>

<!-- ...duration/enroll block... -->
<div><i class="bi bi-clock"></i> @Model.Duration</div>

@if (User.Identity?.IsAuthenticated == true && User.IsInRole("User"))
{
    <button id="enrollBtn" data-course-id="@Model.Id" class="enroll-btn text-white d-block text-center mb-4 border-0 w-100">
        Enroll Now – Limited Seats!
    </button>
}
else if (User.Identity?.IsAuthenticated == true)
{
    <button class="enroll-btn text-white d-block text-center mb-4 border-0 w-100" disabled title="Only student accounts can enroll">
        Enroll Now – Limited Seats!
    </button>
}
else
{
    <a href="/Account/Register" class="enroll-btn text-white d-block text-center mb-4">Enroll Now – Limited Seats!</a>
}

@section Scripts {
    <script>
        $(document).on('click', '#enrollBtn', function () {
            var $btn = $(this);
            $btn.prop('disabled', true).text('Please wait...');
            $.ajax({
                type: 'POST', 
                url: '/Enrollment/Enroll', 
                dataType: 'json',
                data: { courseId: $btn.data('course-id') },
                success: function (result) {
                    if (!result.isError) { location.href = result.returnUrl; }
                    else { errorAlert(result.msg); $btn.prop('disabled', false).text('Enroll Now – Limited Seats!'); }
                },
                error: function () {
                    errorAlert("An error occurred. Please try again.");
                    $btn.prop('disabled', false).text('Enroll Now – Limited Seats!');
                }
            });
        });
    </script>
}