                <div class="carousel-item">
                    <div class="row g-3 justify-content-center">
                        <div class="col-12 col-md-6 col-lg-4">
                            <div class="testimonial-card p-4 text-start">
                                <div class="stars mb-2">
                                    <i class="bi bi-star-fill"></i>
                                    <i class="bi bi-star-fill"></i>
                                    <i class="bi bi-star-fill"></i>
                                    <i class="bi bi-star-fill"></i>
                                    <i class="bi bi-star-fill"></i>
