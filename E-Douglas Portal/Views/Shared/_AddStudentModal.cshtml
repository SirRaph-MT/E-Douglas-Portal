<div class="modal fade" id="add_student" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width: 520px;">
        <div class="modal-content border-0" style="border-radius: 16px; overflow: hidden;">

            <div class="modal-header border-0 pb-0 px-4 pt-4">
                <div>
                    <span style="display:inline-flex;align-items:center;gap:6px;font-size:11px;font-weight:500;
                                 padding:4px 10px;border-radius:20px;background:#E1F5EE;color:#085041;
                                 text-transform:uppercase;letter-spacing:0.05em;margin-bottom:6px;">
                        <span style="width:6px;height:6px;border-radius:50%;background:#0F6E56;display:inline-block;"></span>
                        New Student
                    </span>
                    <h5 class="modal-title mb-0" style="font-size:15px;font-weight:500;">Add Student</h5>
                </div>
                <button type="button" data-bs-dismiss="modal"
                        style="width:28px;height:28px;border-radius:50%;background:#f1f3f5;
                               border:0.5px solid #dee2e6;display:flex;align-items:center;
                               justify-content:center;font-size:13px;color:#6c757d;cursor:pointer;">
                    ✕
                </button>
            </div>

            <div class="modal-body px-4 py-3">
                <form id="addStudentForm">
                    <div class="row g-2 mb-2">
                        <div class="col-6">
                            <label class="form-label mb-1" style="font-size:11px;font-weight:500;text-transform:uppercase;letter-spacing:0.05em;color:#6c757d;">First Name</label>
                            <input type="text" id="studentFirstName" class="form-control"
                                   style="height:34px;font-size:13px;"
                                   placeholder="Samuel" required />
                        </div>
                        <div class="col-6">
                            <label class="form-label mb-1" style="font-size:11px;font-weight:500;text-transform:uppercase;letter-spacing:0.05em;color:#6c757d;">Last Name</label>
                            <input type="text" id="studentLastName" class="form-control"
                                   style="height:34px;font-size:13px;"
                                   placeholder="Ade" required />
                        </div>
                    </div>

                    <div class="row g-2 mb-2">
                        <div class="col-6">
                            <label class="form-label mb-1" style="font-size:11px;font-weight:500;text-transform:uppercase;letter-spacing:0.05em;color:#6c757d;">Email</label>
                            <input type="email" id="studentEmail" class="form-control"
                                   style="height:34px;font-size:13px;"
                                   placeholder="samuel@email.com" required />
                        </div>
                        <div class="col-6">
                            <label class="form-label mb-1" style="font-size:11px;font-weight:500;text-transform:uppercase;letter-spacing:0.05em;color:#6c757d;">Phone</label>
                            <input type="tel" id="studentPhone" class="form-control"
                                   style="height:34px;font-size:13px;"
                                   placeholder="08012345678" required />
                        </div>
                    </div>

                    <div class="row g-2">
                        <div class="col-7">
                            <label class="form-label mb-1" style="font-size:11px;font-weight:500;text-transform:uppercase;letter-spacing:0.05em;color:#6c757d;">Enroll Into Course</label>
                            <select id="studentCourse" class="form-select"
                                    style="height:34px;font-size:13px;">
                                <option value="">Select course</option>
                                <option>Web Design Fundamentals</option>
                                <option>Microsoft Office Mastery</option>
                                <option>Digital Marketing</option>
                                <option>Computer Basics</option>
                            </select>
                        </div>
                        <div class="col-5">
                            <label class="form-label mb-1" style="font-size:11px;font-weight:500;text-transform:uppercase;letter-spacing:0.05em;color:#6c757d;">Payment Status</label>
                            <select id="studentPayment" class="form-select"
                                    style="height:34px;font-size:13px;">
                                <option>Pending</option>
                                <option>Paid</option>
                            </select>
                        </div>
                    </div>
                </form>
            </div>

            <div class="modal-footer border-0 px-4 pb-4 pt-2" style="gap:16px;">
                <button type="button" data-bs-dismiss="modal"
                        style="height:34px;padding:0 20px;font-size:13px;font-weight:500;
                               background:none;border:0.5px solid #dee2e6;border-radius:8px;
                               color:#6c757d;cursor:pointer;">
                    Cancel
                </button>
                <button type="button" onclick="submitAddStudent()"
                        style="height:34px;padding:0 20px;font-size:13px;font-weight:500;
                               background:#0F6E56;border:none;border-radius:8px;
                               color:#fff;cursor:pointer;display:flex;align-items:center;gap:6px;">
                    <svg width="12" height="12" viewBox="0 0 16 16" fill="none">
                        <path d="M8 3v10M3 8h10" stroke="#fff" stroke-width="2" stroke-linecap="round" />
                    </svg>
                    Add Student
                </button>
            </div>

        </div>
    </div>
</div>

