<div class="modal fade" id="add_course" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width: 520px;">
        <div class="modal-content border-0" style="border-radius: 16px; overflow: hidden;">

            <div class="modal-header border-0 pb-0 px-4 pt-4">
                <div>
                    <span style="display:inline-flex;align-items:center;gap:6px;font-size:11px;font-weight:500;
                                 padding:4px 10px;border-radius:20px;background:#E6F1FB;color:#0C447C;
                                 text-transform:uppercase;letter-spacing:0.05em;margin-bottom:6px;">
                        <span style="width:6px;height:6px;border-radius:50%;background:#185FA5;display:inline-block;"></span>
                        New Course
                    </span>
                    <h5 class="modal-title mb-0" style="font-size:15px;font-weight:500;">Create Course</h5>
                </div>
                <button type="button" data-bs-dismiss="modal"
                        style="width:28px;height:28px;border-radius:50%;background:#f1f3f5;
                               border:0.5px solid #dee2e6;display:flex;align-items:center;
                               justify-content:center;font-size:13px;color:#6c757d;cursor:pointer;">
                    ✕
                </button>
            </div>

            <div class="modal-body px-4 py-3">
                <form id="createCourseForm">
                    <div class="row g-2 mb-2">
                        <div class="col-8">
                            <label class="form-label mb-1" style="font-size:11px;font-weight:500;text-transform:uppercase;letter-spacing:0.05em;color:#6c757d;">Course Title</label>
                            <input type="text" id="courseTitle" class="form-control"
                                   style="height:34px;font-size:13px;"
                                   placeholder="Web Design Fundamentals" required />
                        </div>
                        <div class="col-4">
                            <label class="form-label mb-1" style="font-size:11px;font-weight:500;text-transform:uppercase;letter-spacing:0.05em;color:#6c757d;">Duration</label>
                            <input type="text" id="courseDuration" class="form-control"
                                   style="height:34px;font-size:13px;"
                                   placeholder="8 Weeks" required />
                        </div>
                    </div>

                    <div class="row g-2 mb-2">
                        <div class="col-6">
                            <label class="form-label mb-1" style="font-size:11px;font-weight:500;text-transform:uppercase;letter-spacing:0.05em;color:#6c757d;">Price (₦)</label>
                            <div class="input-group" style="height:34px; flex">
                                <span class="input-group-text" style="font-size:12px;height:34px;">₦</span>
                                <input type="number" id="coursePrice" class="form-control"
                                       style="height:34px;font-size:13px;"
                                       placeholder="85000" required />
                            </div>
                        </div>
                        <div class="col-6">
                            <label class="form-label mb-1" style="font-size:11px;font-weight:500;text-transform:uppercase;letter-spacing:0.05em;color:#6c757d;">Max Students</label>
                            <input type="number" id="courseMaxStudents" class="form-control"
                                   style="height:34px;font-size:13px;"
                                   placeholder="20" />
                        </div>
                    </div>

                    <div class="mb-1">
                        <label class="form-label mb-1" style="font-size:11px;font-weight:500;text-transform:uppercase;letter-spacing:0.05em;color:#6c757d;">Description</label>
                        <textarea id="courseDescription" class="form-control" rows="3"
                                  style="font-size:13px;"
                                  placeholder="Brief overview of what students will learn..."></textarea>
                    </div>
                </form>
            </div>

            <div class="modal-footer border-0 px-4 pb-4 pt-2" style="gap:16px;">
                <button type="button" data-bs-dismiss="modal"
                        style="height:34px;padding:0 20px;font-size:13px;font-weight:500;
                               background:none;border:0.5px solid #dee2e6;border-radius:8px;
                               color:#6c757d;cursor:pointer;">
                    Cancel
                </button>
                <button type="button" onclick="submitCreateCourse()"
                        style="height:34px;padding:0 20px;font-size:13px;font-weight:500;
                               background:#185FA5;border:none;border-radius:8px;
                               color:#fff;cursor:pointer;display:flex;align-items:center;gap:6px;">
                    <svg width="12" height="12" viewBox="0 0 16 16" fill="none">
                        <path d="M8 3v10M3 8h10" stroke="#fff" stroke-width="2" stroke-linecap="round" />
                    </svg>
                    Create Course
                </button>
            </div>

        </div>
    </div>
</div>

<script>
    function submitCreateCourse() {
        const title = document.getElementById('courseTitle').value.trim();
        const duration = document.getElementById('courseDuration').value.trim();
        const price = document.getElementById('coursePrice').value.trim();
        if (!title || !duration || !price) {
            alert("Please fill in all required fields.");
            return;
        }
        bootstrap.Modal.getInstance(document.getElementById('add_course')).hide();
        successAlert("Course created successfully!");
    }
</script>