@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Complete Your Profile";
}

<style>
    .profile-page {
        background: linear-gradient(135deg, #f8fafc 0%, #e0f2fe 100%);
        min-height: calc(100vh - 110px);
        padding: 40px 0;
    }

    .profile-card {
        max-width: 820px;
        margin: 0 auto;
        background: white;
        border-radius: 28px;
        box-shadow: 0 25px 50px rgba(21, 3, 122, 0.12);
        overflow: hidden;
        border: 1px solid rgba(0, 212, 255, 0.15);
    }

    .profile-header {
        background: linear-gradient(90deg, #15037A, #00D4FF);
        color: white;
        padding: 35px 40px;
        text-align: center;
    }

    .progress-bar-custom {
        height: 8px;
        background: #e2e8f0;
        border-radius: 50px;
        overflow: hidden;
    }

    .progress-fill {
        height: 100%;
        background: linear-gradient(90deg, #15037A, #00D4FF);
        width: 40%;
        border-radius: 50px;
    }

    .form-section {
        padding: 40px;
    }

    .form-label {
        font-weight: 600;
        color: #0f172a;
    }

    .form-control, .form-select {
        border-radius: 14px;
        padding: 14px 18px;
        border: 2px solid #e2e8f0;
        transition: all 0.3s ease;
    }

        .form-control:focus, .form-select:focus {
            border-color: #00D4FF;
            box-shadow: 0 0 0 4px rgba(0, 212, 255, 0.15);
        }

    .passport-preview {
        width: 140px;
        height: 140px;
        border-radius: 20px;
        border: 4px solid #00D4FF;
        object-fit: cover;
        background: #f1f5f9;
    }

    .btn-complete {
        background: linear-gradient(90deg, #15037A, #00D4FF);
        border: none;
        border-radius: 50px;
        padding: 16px 50px;
        font-size: 1.2rem;
        font-weight: 600;
        box-shadow: 0 10px 30px rgba(0, 212, 255, 0.4);
    }

        .btn-complete:hover {
            transform: translateY(-4px);
            box-shadow: 0 20px 40px rgba(0, 212, 255, 0.5);
        }
</style>

<div class="profile-page">
    <div class="profile-card" data-aos="fade-up">

        <!-- Header -->
        <div class="profile-header">
            <h2 class="mb-2">Complete Your Profile</h2>
            <p class="mb-0 opacity-90">Just a few more details and you're ready to start learning!</p>

            <!-- Progress -->
            <div class="mt-4">
                <div class="d-flex justify-content-between text-white small mb-1">
                    <span>Step 1 of 2</span>
                    <span>40% Complete</span>
                </div>
                <div class="progress-bar-custom">
                    <div class="progress-fill"></div>
                </div>
            </div>
        </div>

        <div class="form-section">
            <form id="completeProfileForm" enctype="multipart/form-data">
                <div class="row g-4">

                    <!-- Date of Birth -->
                    <div class="col-md-6">
                        <label class="form-label">Date of Birth</label>
                        <input type="date" id="dateOfBirth" name="DateOfBirth" class="form-control" required />
                    </div>

                    <!-- Student Type -->
                    <div class="col-md-6">
                        <label class="form-label">Student Type</label>
                        <select id="studentType" name="StudentType" class="form-select" required>
                            <option value="">Select type...</option>
                            <option value="FullTime">Full-Time Student</option>
                            <option value="WorkingClass">Working-Class Student</option>
                            <option value="Weekend">Weekend Student</option>
                        </select>
                    </div>

                    <!-- Sponsor Name -->
                    <div class="col-12">
                        <label class="form-label">Sponsor / Guardian Name</label>
                        <input type="text" id="sponsorName" name="SponsorName" class="form-control" placeholder="Full name of sponsor" required />
                    </div>

                    <!-- Sponsor Phone -->
                    <div class="col-md-6">
                        <label class="form-label">Sponsor Phone Number</label>
                        <input type="tel" id="sponsorPhone" name="SponsorPhone" class="form-control" placeholder="080xxxxxxxx" required />
                    </div>

                    <!-- Sponsor Address -->
                    <div class="col-md-6">
                        <label class="form-label">Sponsor Address</label>
                        <input type="text" id="sponsorAddress" name="SponsorAddres" class="form-control" placeholder="Full address" required />
                    </div>

                    <!-- Passport Upload -->
                    <div class="col-12">
                        <label class="form-label">Upload Passport Photograph</label>
                        <div class="d-flex align-items-center gap-4">
                            <div>
                                <input type="file" id="passportFile" name="passportFile" accept="image/*" class="form-control" style="width: 280px;" />
                                <small class="text-muted">JPG, PNG • Max 2MB</small>
                            </div>
                            <img id="passportPreview" src="~/images/default-passport.png" alt="Preview" class="passport-preview" onerror="this.style.display='none'">
                        </div>
                    </div>

                </div>

                <div class="text-center mt-5">
                    <button type="button" onclick="submitCompleteProfile()" class="btn btn-complete text-white px-5">
                        Save Profile & Continue to Dashboard
                        <i class="bi bi-arrow-right ms-2"></i>
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    // Live passport preview
    document.getElementById('passportFile').addEventListener('change', function (e) {
        const file = e.target.files[0];
        if (file) {
            const reader = new FileReader();
            reader.onload = function (ev) {
                document.getElementById('passportPreview').src = ev.target.result;
                document.getElementById('passportPreview').style.display = 'block';
            };
            reader.readAsDataURL(file);
        }
    });

    // Submit function (calls your existing backend)
    function submitCompleteProfile() {
        const formData = new FormData(document.getElementById('completeProfileForm'));

        fetch('/Student/CompleteProfile', {
            method: 'POST',
            body: formData
        })
        .then(response => response.json())
        .then(data => {
            if (!data.isError) {
                successAlertWithRedirect(data.msg || "Profile completed successfully!", data.returnUrl || "/Student/Index");
            } else {
                errorAlert(data.msg || "Something went wrong");
            }
        })
        .catch(() => errorAlert("Network error. Please try again."));
    }
</script>